{
  "name": "agent-run-digest-skill",
  "version": "0.1.0",
  "description": "Local-first agent transcript digest skill for audits and PR evidence.",
  "type": "module",
  "license": "MIT",
  "bin": {
    "agent-run-digest": "bin/agent-run-digest.js"
  },
  "exports": {
    ".": "./src/digest.js"
  },
  "files": [
    "bin",
    "src",
    "docs",
    "fixtures",
    "SKILL.md",
    "README.md",
    "LICENSE",
    "SECURITY.md",
    "CHANGELOG.md",
    "CONTRIBUTING.md"
  ],
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "smoke": "node bin/agent-run-digest.js fixtures/sample-run.jsonl --format markdown",
    "package:smoke": "node scripts/package-smoke.js",
    "release:check": "npm run check && npm test && npm run build && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "local-first",
    "cli",
    "audit"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/agent-run-digest-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/agent-run-digest-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/agent-run-digest-skill#readme",
  "engines": {
    "node": ">=18"
  }
}
